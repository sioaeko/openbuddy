RARITY_WEIGHTS   = {"common": 65, "rare": 28, "legendary": 7}
STAGES           = [(0, "egg"), (3, "baby"), (12, "adult"), (30, "elder")]
EGG_HATCH_AT     = 3
# tokscale 누적 토큰(input+output+reasoning)을 진행도로 환산: 1단위 ≈ 이 토큰 수
TOKENS_PER_PROGRESS_UNIT = 100_000
# 세션 3회 대신, 이 토큰만으로도 알 부화
TOKENS_TO_HATCH            = 250_000

# ── State management ──────────────────────────────────────────────────────────

def get_stage(progress: int) -> str:
    stage = "egg"
    for threshold, name in STAGES:
        if progress >= threshold:
            stage = name
    return stage

def get_next_stage_at(progress: int) -> int | None:
    for threshold, _ in STAGES:
        if threshold > progress:
            return threshold
    return None

def progress_points(state: dict) -> int:
    """래퍼 세션 수와 tokscale 누적 토큰 중 더 큰 쪽을 진행도로 씀 (둘 다 성장에 기여)."""
    sess = int(state.get("sessions", 0) or 0)
    lt   = int(state.get("lifetime_tokens", 0) or 0)
    from_tokens = lt // TOKENS_PER_PROGRESS_UNIT
    return max(sess, from_tokens)

def get_stage_for_state(state: dict) -> str:
    return get_stage(progress_points(state))

def egg_should_hatch(state: dict) -> bool:
    if state.get("hatched"):
        return False
    return state.get("sessions", 0) >= EGG_HATCH_AT or int(state.get("lifetime_tokens", 0) or 0) >= TOKENS_TO_HATCH

def pick_creature() -> str:
    pool = []
    for key, data in CREATURES.items():
        pool.extend([key] * RARITY_WEIGHTS[data["rarity"]])
    return random.choice(pool)

def migrate_legacy() -> dict | None:
    """Check for old codex-buddy / anygochi state and migrate it."""
    for legacy_path in LEGACY_PATHS:
        if legacy_path.exists():
            try:
                with open(legacy_path) as f:
                    old = json.load(f)
                state = {
                    "creature":      old.get("creature", pick_creature()),
                    "sessions":      old.get("sessions", 0),
                    "tool_sessions": old.get("tool_sessions", {"legacy": old.get("sessions", 0)}),
                    "daily_log":     old.get("daily_log", {}),
                    "created_at":    old.get("created_at", datetime.now().isoformat()),
                    "last_session":  old.get("last_session"),
                    "hatched":       old.get("hatched", False),
                    "lifetime_tokens": old.get("lifetime_tokens", 0),
                    "tokscale_synced_at": old.get("tokscale_synced_at"),
                    "lifetime_cost_usd": old.get("lifetime_cost_usd", 0),
                }
                save_state(state)
                legacy_path.rename(legacy_path.with_suffix(".json.bak"))
                return state
            except Exception:
                pass
    return None

def load_state() -> dict:
    if STATE_FILE.exists():
        try:
            with open(STATE_FILE) as f:
                state = json.load(f)
            upgraded = False
            if "tool_sessions" not in state:
                state["tool_sessions"] = {"legacy": state.get("sessions", 0)}
                upgraded = True
            if "daily_log" not in state:
                state["daily_log"] = {}
                upgraded = True
            if "lifetime_tokens" not in state:
                state["lifetime_tokens"] = 0
                upgraded = True
            if "tokscale_synced_at" not in state:
                state["tokscale_synced_at"] = None
                upgraded = True
            if "lifetime_cost_usd" not in state:
                state["lifetime_cost_usd"] = 0.0
                upgraded = True
            if upgraded:
                save_state(state)
            return state
        except (json.JSONDecodeError, KeyError):
            pass

    migrated = migrate_legacy()
    if migrated:
        return migrated

    creature_key = pick_creature()
    state = {
        "creature":      creature_key,
        "sessions":      0,
        "tool_sessions": {},
        "daily_log":     {},
        "created_at":    datetime.now().isoformat(),
        "last_session":  None,
        "hatched":       False,
        "lifetime_tokens": 0,
        "tokscale_synced_at": None,
        "lifetime_cost_usd": 0.0,
    }
    save_state(state)
    return state

def save_state(state: dict):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)

# ── Tokscale integration ─────────────────────────────────────────────────────

def _nodejs_bin_dirs() -> list[str]:
    """Extra directories to prepend to PATH so npx is visible (esp. Windows + IDE shells)."""
    if not IS_WINDOWS:
        return []
    out: list[str] = []
    for key in ("ProgramFiles", "ProgramFiles(x86)"):
        base = os.environ.get(key)
        if base:
            d = os.path.join(base, "nodejs")
            if os.path.isfile(os.path.join(d, "npx.cmd")) or os.path.isfile(os.path.join(d, "npx.exe")):
                out.append(d)
    local = os.environ.get("LOCALAPPDATA", "")
    if local:
        d = os.path.join(local, "Programs", "nodejs")
        if os.path.isfile(os.path.join(d, "npx.cmd")) or os.path.isfile(os.path.join(d, "npx.exe")):
            out.append(d)
    return out


def _tokscale_env() -> dict:
    env = {**os.environ, "NODE_NO_WARNINGS": "1"}
    extra = _nodejs_bin_dirs()
    if extra:
        prefix = os.pathsep.join(dict.fromkeys(extra))  # de-dupe, preserve order
        env["PATH"] = prefix + os.pathsep + env.get("PATH", "")
    return env


def _resolve_npx() -> str | None:
    """Absolute path to npx — required on Windows where CreateProcess won't find bare 'npx'."""
    for name in ("npx", "npx.cmd", "npx.exe"):
        w = shutil.which(name)
        if w:
            return w
    for d in _nodejs_bin_dirs():
        for leaf in ("npx.cmd", "npx.exe"):
            p = os.path.join(d, leaf)
            if os.path.isfile(p):
                return p
    return None


def get_tokscale_data(*period_flags: str, timeout_sec: float = 120) -> dict | None:
    """Run tokscale --json. period_flags e.g. ('--today',) or () for all-time."""
    npx = _resolve_npx()
    if not npx:
        return None
    cmd = [npx, "-y", "tokscale@latest", "--json", "--no-spinner", *period_flags]
    try:
        result = subprocess.run(
            cmd,
            capture_output=True, text=True, timeout=timeout_sec,
            env=_tokscale_env(),
        )
        if result.returncode == 0 and result.stdout.strip():
            return json.loads(result.stdout.strip())
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError):
        pass
    return None


def parse_tokscale_report(data: dict | list | None) -> dict:
    """Normalize tokscale JSON → display + lifetime XP (input+output+reasoning)."""
    total_input = total_output = total_reasoning = 0
    total_cost = 0.0
    platforms: dict[str, int] = {}

    if isinstance(data, dict) and data.get("entries"):
        entries = data["entries"]
        for e in entries:
            if not isinstance(e, dict):
                continue
            cl = e.get("client") or e.get("platform") or e.get("tool") or "unknown"
            inp = int(e.get("input") or e.get("input_tokens") or e.get("inputTokens") or 0)
            out = int(e.get("output") or e.get("output_tokens") or e.get("outputTokens") or 0)
            reason = int(e.get("reasoning") or 0)
            cost = float(e.get("cost") or 0)
            total_cost += cost
            platforms[cl] = platforms.get(cl, 0) + inp + out + reason
        ti = data.get("totalInput")
        to = data.get("totalOutput")
        if ti is not None and to is not None:
            total_input = int(ti)
            total_output = int(to)
            total_reasoning = sum(
                int(e.get("reasoning") or 0) for e in entries if isinstance(e, dict)
            )
        else:
            for e in entries:
                if not isinstance(e, dict):
                    continue
                total_input += int(e.get("input") or e.get("input_tokens") or 0)
                total_output += int(e.get("output") or e.get("output_tokens") or 0)
                total_reasoning += int(e.get("reasoning") or 0)
        tc = data.get("totalCost")
        if tc is not None:
            try:
                total_cost = float(tc)
            except (TypeError, ValueError):
                pass
    elif isinstance(data, list):
        for entry in data:
            if not isinstance(entry, dict):
                continue
            inp = int(entry.get("input_tokens", 0) or entry.get("inputTokens", 0) or entry.get("input", 0))
            out = int(entry.get("output_tokens", 0) or entry.get("outputTokens", 0) or entry.get("output", 0))
            reason = int(entry.get("reasoning", 0) or 0)
            cost = float(entry.get("cost", 0) or 0)
            plat = str(entry.get("platform", entry.get("tool", entry.get("client", "unknown"))))
            total_input += inp
            total_output += out
            total_reasoning += reason
            total_cost += cost
            platforms[plat] = platforms.get(plat, 0) + inp + out + reason
    elif isinstance(data, dict):
        total_input = int(
            data.get("totalInput")
            or data.get("input_tokens", data.get("totalInputTokens", 0))
            or 0
        )
        total_output = int(
            data.get("totalOutput")
            or data.get("output_tokens", data.get("totalOutputTokens", 0))
            or 0
        )
        total_reasoning = int(data.get("totalReasoning", 0) or 0)
        total_cost = float(data.get("totalCost", data.get("cost", 0)) or 0)
        for p in data.get("platforms", data.get("tools", [])):
            if isinstance(p, dict):
                pname = p.get("name", p.get("platform", "?"))
                ptok = int(p.get("tokens", p.get("totalTokens", 0)) or 0)
                platforms[str(pname)] = ptok

    total_xp = total_input + total_output + total_reasoning
    return {
        "total_input": total_input,
        "total_output": total_output,
        "total_reasoning": total_reasoning,
        "total_xp": total_xp,
        "total_cost": total_cost,
        "platforms": platforms,
    }


def apply_tokscale_to_state(
    state: dict,
    lifetime_xp: int,
    *,
    total_cost: float | None = None,
    run_animations: bool = True,
) -> None:
    """Monotonic merge of tokscale lifetime total into state and optionally run hatch/evolve."""
    old_hatched = bool(state.get("hatched"))
    old_stage = get_stage_for_state(state)
    prev_lt = int(state.get("lifetime_tokens", 0) or 0)
    state["lifetime_tokens"] = max(prev_lt, int(lifetime_xp))
    state["tokscale_synced_at"] = datetime.now().isoformat()
    if total_cost is not None:
        try:
            c = float(total_cost)
            prev_c = float(state.get("lifetime_cost_usd") or 0)
            state["lifetime_cost_usd"] = max(prev_c, c)
        except (TypeError, ValueError):
            pass
    new_stage = get_stage_for_state(state)
    names = [n for _, n in STAGES if n != "egg"]

    if not old_hatched and egg_should_hatch(state):
        state["hatched"] = True
        save_state(state)
        if run_animations:
            hatch_animation(state)
            st = get_stage_for_state(state)
            try:
                t_i = names.index(st)
            except ValueError:
                t_i = 0
            for j in range(1, t_i + 1):
                evolve_animation(state, names[j])
    elif old_hatched and run_animations:
        try:
            i0 = names.index(old_stage)
            i1 = names.index(new_stage)
        except ValueError:
            i0 = i1 = 0
        if i1 > i0:
            for j in range(i0 + 1, i1 + 1):
                evolve_animation(state, names[j])

    save_state(state)

def format_tokens(n: int) -> str:
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}K"
    return str(n)

def format_cost(c: float) -> str:
    if c >= 1.0:
        return f"${c:.2f}"
    return f"${c:.4f}"


def _lifetime_cost_usd(state: dict) -> float:
    try:
        return float(state.get("lifetime_cost_usd") or 0)
    except (TypeError, ValueError):
        return 0.0


def _codex_context_cost_line(state: dict) -> str:
    c = _lifetime_cost_usd(state)
    if c > 0:
        return f"Est. spend (tokscale, all-time): {format_cost(c)}"
    return "Est. spend: run `openbuddy sync` to load tokscale total $"


# ── Rendering ─────────────────────────────────────────────────────────────────

def _term_cols() -> int:
    """Prefer COLUMNS (set by tmux/bash per pane) over ioctl — avoids full-screen width in a narrow split."""
    raw = os.environ.get("COLUMNS")
    if raw is not None and str(raw).strip().isdigit():
        return max(10, min(4096, int(str(raw).strip())))
    try:
        return max(10, os.get_terminal_size().columns)
    except OSError:
        return 80


def _parse_interval_seconds(raw: str) -> float:
    try:
        v = float(str(raw).strip())
    except (TypeError, ValueError):
        return 6.0
    if v < 0.5:
        return 0.5
    if v > 3600:
        return 3600.0
    return v


def _watch_interval_seconds() -> float:
    """Env OPENBUDDY_WATCH_INTERVAL, else config watch_interval, else 6."""
    raw = os.environ.get("OPENBUDDY_WATCH_INTERVAL")
    if raw is None or raw == "":
        wc = _user_config().get("watch_interval")
        raw = str(wc) if wc is not None else "6"
    return _parse_interval_seconds(raw)


def _compact_auto_threshold() -> int:
    """Columns below this use compact layout (unless OPENBUDDY_COMPACT=0/1)."""
    raw = os.environ.get("OPENBUDDY_COMPACT_THRESHOLD")
    if raw is not None and raw != "":
        try:
            return max(20, min(200, int(raw)))
        except ValueError:
            pass
    cfg = _user_config()
    t = cfg.get("compact_auto_threshold")
    if t is not None:
        try:
            return max(20, min(200, int(t)))
        except (TypeError, ValueError):
            pass
    return 48


def _full_ui_mode() -> bool:
    """Wide Tamagotchi panel (stats, full ASCII, description). Off by default to save space."""
    e = os.environ.get("OPENBUDDY_FULL_UI")
    if e == "1":
        return True
    if e == "0":
        return False
    cfg = _user_config().get("full_ui")
    if isinstance(cfg, bool):
        return cfg
    if isinstance(cfg, str) and cfg.lower() in ("1", "true", "yes"):
        return True
    return False


def _want_compact(term_width: Optional[int]) -> bool:
    """Compact = less lines (short ASCII, no stat bars). Default: always on unless FULL_UI mode."""
    ev = os.environ.get("OPENBUDDY_COMPACT")
    if ev == "1":
        return True
    if ev == "0":
        return False
    th = _compact_auto_threshold()
    if _full_ui_mode():
        return term_width is not None and term_width < th
    # Space-saving default: compact in narrow tmux panes and on full-width terminals
    return True


def _panel_width(term_width: Optional[int]) -> int:
    if term_width is None:
        return 38
    return max(22, min(38, term_width - 1))


def stat_bar(value: int, width: int = 8) -> str:
    filled = round((value / 10) * width)
    return "\u2588" * filled + "\u2591" * (width - filled)

def _tool_summary(state: dict) -> str:
    ts = state.get("tool_sessions", {})
    if not ts:
        return ""
    parts = [f"{t}:{n}" for t, n in sorted(ts.items(), key=lambda x: -x[1])[:3]]
    return "  ".join(parts)

def render_rich(state: dict, message: str = None, term_width: Optional[int] = None):
    console = Console()
    pw = _panel_width(term_width)
    sessions = state["sessions"]
    lt       = int(state.get("lifetime_tokens", 0) or 0)
    prog     = progress_points(state)
    stage    = get_stage_for_state(state)
    is_egg   = not state.get("hatched", False)

    if is_egg:
        creature_key = state["creature"]
        egg_art = CREATURES[creature_key]["ascii"]["egg"]
        content = Text()
        content.append("  ???\n",                style="bold dim white")
        content.append("  The Unknown\n\n",       style="dim white")
        content.append(f"  EGG  ",               style="bold white")
        content.append(
            f"Sessions {sessions}/{EGG_HATCH_AT}  ·  tok {format_tokens(lt)}/{format_tokens(TOKENS_TO_HATCH)}\n\n",
            style="dim white",
        )
        for line in egg_art:
            content.append(f"  {line}\n",        style="bold white")
        content.append("\n  Something stirs inside...\n", style="dim white")
        left_s = max(0, EGG_HATCH_AT - sessions)
        left_t = max(0, TOKENS_TO_HATCH - lt)
        content.append(
            f"\n  \U0001f95a {left_s} more session(s) or {format_tokens(left_t)} more tokens (tokscale)\n",
            style="italic dim yellow",
        )
        lc = _lifetime_cost_usd(state)
        if lc > 0:
            content.append(f"  \U0001f4b0 {format_cost(lc)} (tokscale est.)\n", style="dim white")
        if message:
            content.append(f'\n  \U0001f4ac "{message}"', style="italic white")
        console.print(Panel(content,
            title="[bold white]\u2726 OPENBUDDY \u2726[/]",
            border_style="white", width=pw, padding=(0, 1)))
        return

    creature = CREATURES[state["creature"]]
    color    = creature["color"]
    ascii_art = creature["ascii"][stage]
    stats    = creature["stats"]
    rarity_colors = {"common": "white", "rare": "bright_cyan", "legendary": "bright_yellow"}
    rarity_color  = rarity_colors[creature["rarity"]]
    stage_icons   = {"egg": "\U0001f95a", "baby": "\U0001f423", "adult": "\u2728", "elder": "\U0001f451"}
    next_at  = get_next_stage_at(prog)
    tool_str = _tool_summary(state)
    tok_pts  = lt // TOKENS_PER_PROGRESS_UNIT

    content = Text()
    content.append(f"  {creature['name']}",      style=f"bold {color}")
    content.append(f"  [{creature['rarity'].upper()}]\n", style=f"bold {rarity_color}")
    content.append(f"  {creature['title']}\n\n", style=f"dim {color}")
    content.append(f"  {stage_icons[stage]} {stage.upper()}", style="bold white")
    content.append(f"  Progress: {prog}",        style="dim white")
    if next_at:
        content.append(f"  \u2192{next_at}",     style="dim yellow")
    content.append("\n", style="dim white")
    content.append(f"  (sess {sessions}  ·  tokscale \u2248{tok_pts}  ·  {format_tokens(lt)})\n", style="dim white")
    lc = _lifetime_cost_usd(state)
    if lc > 0:
        content.append(f"  \U0001f4b0 {format_cost(lc)} (tokscale est.)\n", style="dim white")
    content.append("\n")
    if tool_str:
        content.append(f"  \U0001f6e0  {tool_str}\n", style="dim white")
    content.append("\n")
    for line in ascii_art:
        content.append(f"  {line}\n",            style=f"bold {color}")
    content.append("\n")
    content.append(f"  \U0001f9e0  {stat_bar(stats['intelligence'])}  {stats['intelligence']}/10\n", style="bright_white")
    content.append(f"  \u26a1  {stat_bar(stats['speed'])}  {stats['speed']}/10\n",               style="bright_white")
    content.append(f"  \U0001f3a8  {stat_bar(stats['creativity'])}  {stats['creativity']}/10\n",  style="bright_white")
    content.append(f"  \U0001f4aa  {stat_bar(stats['endurance'])}  {stats['endurance']}/10\n",    style="bright_white")
    content.append(f"\n  {creature['description']}\n", style="dim white")
    if message:
        content.append(f'\n  \U0001f4ac "{message}"',    style=f"italic {color}")

    console.print(Panel(content,
        title=f"[bold {color}]\u2726 OPENBUDDY \u2726[/]",
        border_style=color, width=pw, padding=(0, 1)))

def render_rich_compact(state: dict, message: str = None, term_width: Optional[int] = None):
    """Minimal panel for narrow tmux splits (space-efficient)."""
    tw = term_width or 28
    # Cap width so a mistaken huge ioctl width does not inflate the panel
    tw = min(tw, 48)
    pw = max(12, min(22, tw - 1))
    console = Console(width=pw)
    sessions = state["sessions"]
    lt = int(state.get("lifetime_tokens", 0) or 0)
    prog = progress_points(state)
    stage = get_stage_for_state(state)
    is_egg = not state.get("hatched", False)

    if is_egg:
        creature_key = state["creature"]
        egg_art = CREATURES[creature_key]["ascii"]["egg"]
        content = Text()
        content.append("  ???  EGG\n", style="bold dim white")
        content.append(
            f"  sess {sessions}/{EGG_HATCH_AT}  ·  tok {format_tokens(lt)}/{format_tokens(TOKENS_TO_HATCH)}\n",
            style="dim white",
        )
        for line in egg_art[:2]:
            content.append(f"  {line}\n", style="bold white")
        if message:
            content.append(f'\n  \U0001f4ac "{message}"', style="italic dim white")
        console.print(Panel(content,
            title="[bold white]\u2726 OB \u2726[/]",
            border_style="white", width=pw, padding=(0, 0)))
        return

    creature = CREATURES[state["creature"]]
    color = creature["color"]
    ascii_art = creature["ascii"][stage]
    rarity_colors = {"common": "white", "rare": "bright_cyan", "legendary": "bright_yellow"}
    rarity_color = rarity_colors[creature["rarity"]]
    stage_icons = {"egg": "\U0001f95a", "baby": "\U0001f423", "adult": "\u2728", "elder": "\U0001f451"}
    next_at = get_next_stage_at(prog)
    tool_str = _tool_summary(state)
    tok_pts = lt // TOKENS_PER_PROGRESS_UNIT

    content = Text()
    content.append(f"  {creature['name']}", style=f"bold {color}")
    content.append(f"  [{creature['rarity'].upper()}]\n", style=f"bold {rarity_color}")
    content.append(f"  {stage_icons[stage]} {stage.upper()}", style="bold white")
    content.append(f"  ·  prog {prog}", style="dim white")
    if next_at:
        content.append(f"  \u2192{next_at}", style="dim yellow")
    content.append("\n", style="dim white")
    content.append(
        f"  sess {sessions}  ·  tok ~{tok_pts}  ·  {format_tokens(lt)}\n",
        style="dim white",
    )
    if tool_str:
        content.append(f"  \U0001f6e0  {tool_str}\n", style="dim white")
    content.append("\n")
    for line in ascii_art[:2]:
        content.append(f"  {line}\n", style=f"bold {color}")
    if message:
        content.append(f'\n  \U0001f4ac "{message}"', style=f"italic {color}")

    console.print(Panel(content,
        title=f"[bold {color}]\u2726 OB \u2726[/]",
        border_style=color, width=pw, padding=(0, 0)))

def render_plain(state: dict, message: str = None, term_width: Optional[int] = None):
    pw = _panel_width(term_width)
    sessions = state["sessions"]
    lt       = int(state.get("lifetime_tokens", 0) or 0)
    prog     = progress_points(state)
    stage    = get_stage_for_state(state)
    is_egg   = not state.get("hatched", False)
    print("=" * pw)
    print("  \u2726 OPENBUDDY \u2726")
    print("=" * pw)
    if is_egg:
        print(f"  Stage: EGG  sessions {sessions}/{EGG_HATCH_AT}  tok {lt}/{TOKENS_TO_HATCH}")
        print()
        for line in CREATURES[state["creature"]]["ascii"]["egg"]:
            print(f"  {line}")
        print("\n  Something stirs inside...")
        lc = _lifetime_cost_usd(state)
        if lc > 0:
            print(f"  Spend (tokscale est.): {format_cost(lc)}")
    else:
        creature = CREATURES[state["creature"]]
        stats    = creature["stats"]
        tool_str = _tool_summary(state)
        tok_pts  = lt // TOKENS_PER_PROGRESS_UNIT
        print(f"  {creature['name']}  [{creature['rarity'].upper()}]")
        print(f"  {creature['title']}")
        print(f"  {stage.upper()}  Progress: {prog}  (sess {sessions}, tokscale ~{tok_pts}, {lt} tok)")
        lc = _lifetime_cost_usd(state)
        if lc > 0:
            print(f"  Spend (tokscale est.): {format_cost(lc)}")
        if tool_str:
            print(f"  Tools: {tool_str}")
        print()
        for line in creature["ascii"][stage]:
            print(f"  {line}")
        print()
        print(f"  INT  {stat_bar(stats['intelligence'])}  {stats['intelligence']}/10")
        print(f"  SPD  {stat_bar(stats['speed'])}  {stats['speed']}/10")
        print(f"  CRE  {stat_bar(stats['creativity'])}  {stats['creativity']}/10")
        print(f"  END  {stat_bar(stats['endurance'])}  {stats['endurance']}/10")
    if message:
        print(f'\n  \U0001f4ac "{message}"')
    print("=" * pw)

def render_plain_compact(state: dict, message: str = None, term_width: Optional[int] = None):
    tw = min(term_width or 28, 48)
    pw = max(12, min(22, tw - 1))
    sessions = state["sessions"]
    lt = int(state.get("lifetime_tokens", 0) or 0)
    prog = progress_points(state)
    stage = get_stage_for_state(state)
    is_egg = not state.get("hatched", False)
    print("=" * pw)
    print("  \u2726 OB \u2726")
    print("=" * pw)
    if is_egg:
        print(f"  EGG  sess {sessions}/{EGG_HATCH_AT}  tok {lt}/{TOKENS_TO_HATCH}")
        for line in CREATURES[state["creature"]]["ascii"]["egg"][:2]:
            print(f"  {line}")
    else:
        creature = CREATURES[state["creature"]]
        tok_pts = lt // TOKENS_PER_PROGRESS_UNIT
        tool_str = _tool_summary(state)
        print(f"  {creature['name']} [{creature['rarity'].upper()}]")
        print(f"  {stage.upper()}  prog {prog}  sess {sessions}  tok ~{tok_pts}  {lt} tok")
        if tool_str:
            print(f"  Tools: {tool_str}")
        for line in creature["ascii"][stage][:2]:
            print(f"  {line}")
    if message:
        print(f'\n  \U0001f4ac "{message}"')
    print("=" * pw)

def render(state: dict, message: str = None, *, term_width: Optional[int] = None):
    compact = _want_compact(term_width)
    if HAS_RICH:
        if compact:
            render_rich_compact(state, message, term_width)
        else:
            render_rich(state, message, term_width)
    else:
        if compact:
            render_plain_compact(state, message, term_width)
        else:
            render_plain(state, message, term_width)

# ── Animations ────────────────────────────────────────────────────────────────

def hatch_animation(state: dict):
    creature = CREATURES[state["creature"]]
    color    = creature["color"]
    if HAS_RICH:
        console = Console()
        frames = [
            ["   .~~~~.", "  ( ???? )", "   `~~~~'"],
            ["   .~~~~.", "  ( *~~* )", "   `-||-'"],
            ["  .*~~~~*.", "  (* oo *)", "   `~~~~'"],
            ["  .\u2571~~~~\u2572.", "  \u2571 !! !! \u2572", "   `~~~~'"],
        ]
        for frame in frames:
            console.clear()
            console.print("\n  [bold yellow]\u2726 Your egg is hatching! \u2726[/]\n")
            for line in frame:
                console.print(f"  [bold white]{line}[/]")
            time.sleep(0.45)
        console.clear()
        console.print(f"\n  [bold {color}]\u2726 {creature['name']} has hatched! \u2726[/]")
        console.print(f"  [bold {color}][{creature['rarity'].upper()}] \u2014 {creature['title']}[/]\n")
        for line in creature["ascii"]["baby"]:
            console.print(f"  [bold {color}]{line}[/]")
        console.print(f'\n  [italic {color}]"...hello."[/]\n')
        console.print(f"  [dim]{creature['description']}[/]\n")
        time.sleep(2.5)
    else:
        print("\n  \u2726 Your egg is hatching! \u2726\n")
        time.sleep(1)
        print(f"  \u2726 {creature['name']} has hatched! \u2726")
        print(f"  [{creature['rarity'].upper()}] \u2014 {creature['title']}")
        for line in creature["ascii"]["baby"]:
            print(f"  {line}")
        print('\n  "...hello."\n')
        time.sleep(1.5)

def evolve_animation(state: dict, new_stage: str):
    creature = CREATURES[state["creature"]]
    color    = creature["color"]
    if HAS_RICH:
        console = Console()
        console.print(f"\n  [bold {color}]\u2726 {creature['name']} evolved to {new_stage.upper()}! \u2726[/]\n")
        for line in creature["ascii"][new_stage]:
            console.print(f"  [bold {color}]{line}[/]")
        whisper = random.choice(creature["quotes"]["idle"])
        console.print(f'\n  [italic dim {color}]"{whisper}"[/]\n')
        time.sleep(2)
    else:
        print(f"\n  \u2726 {creature['name']} evolved to {new_stage.upper()}! \u2726\n")
        for line in creature["ascii"][new_stage]:
            print(f"  {line}")
        print(f'\n  "{random.choice(creature["quotes"]["idle"])}"\n')
        time.sleep(1.5)

# ── Quotes ────────────────────────────────────────────────────────────────────

def get_quote(state: dict, working: bool = False) -> str:
    if not state.get("hatched"):
        return random.choice(["*muffled tapping*", "...", "*tap tap*", "Soon..."])
    creature = CREATURES[state["creature"]]
    hour = datetime.now().hour
    pool = creature["quotes"]["working" if working else "idle"]
    # Slight time-of-day bias so repeats feel less mechanical
    if not working and 5 <= hour < 12 and random.random() < 0.25:
        morning = [q for q in pool if any(w in q.lower() for w in ("coffee", "compile", "slow", "wait", "patience"))]
        if morning:
            return random.choice(morning)
    if not working and (hour >= 22 or hour < 5):
        if random.random() < 0.2:
            night = [q for q in pool if len(q) < 28]
            if night:
                return random.choice(night)
    return random.choice(pool)

# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_session(state: dict, tool: str = "unknown", silent: bool = False, hook_mode: bool = False):
    """Increment session. silent=True suppresses panel; hook_mode skips animations (Codex Stop hook)."""
    old_stage = get_stage_for_state(state)
    state["sessions"] += 1
    state["tool_sessions"][tool] = state["tool_sessions"].get(tool, 0) + 1
    state["last_session"] = datetime.now().isoformat()

    # Daily log
    today = datetime.now().strftime("%Y-%m-%d")
    daily = state.get("daily_log", {})
    if today not in daily:
        daily[today] = {"sessions": 0, "tools": {}}
    daily[today]["sessions"] += 1
    daily[today]["tools"][tool] = daily[today]["tools"].get(tool, 0) + 1
    state["daily_log"] = daily

    save_state(state)

    if not state.get("hatched") and egg_should_hatch(state):
        state["hatched"] = True
        save_state(state)
        if not hook_mode:
            hatch_animation(state)
            names = [n for _, n in STAGES if n != "egg"]
            st = get_stage_for_state(state)
            try:
                t_i = names.index(st)
            except ValueError:
                t_i = 0
            for j in range(1, t_i + 1):
                evolve_animation(state, names[j])
            save_state(state)
    elif state.get("hatched") and old_stage != new_stage and not hook_mode:
        evolve_animation(state, new_stage)

    if not silent:
        render(state, message=get_quote(state, working=True), term_width=_term_cols())

def cmd_show(state: dict):
    render(state, message=get_quote(state), term_width=_term_cols())

def cmd_watch(state: dict):
    def _clear():
        if HAS_RICH:
            Console().clear()
        elif IS_WINDOWS:
            os.system("cls")
        else:
            os.system("clear")

    def _set_tty_title():
        # Helps tmux wrappers find this pane via #{pane_title} on many setups
        if IS_WINDOWS:
            return
        try:
            if sys.stdout.isatty():
                sys.stdout.write("\033]2;openbuddy watch\007")
                sys.stdout.flush()
        except (OSError, AttributeError):
            pass

    _set_tty_title()
    try:
        while True:
            _clear()
            state = load_state()
            render(state, message=get_quote(state), term_width=_term_cols())
            time.sleep(_watch_interval_seconds())
    except KeyboardInterrupt:
        pass

def cmd_reset():
    if STATE_FILE.exists():
        STATE_FILE.unlink()
    msg = "openbuddy reset. A new egg awaits..."
    Console().print(f"[bold yellow]{msg}[/]") if HAS_RICH else print(msg)


def cmd_doctor() -> int:
    """Print install/runtime checks. Returns 0 if no hard failures, 1 otherwise."""
    script = Path(__file__).resolve()
    rows: list[tuple[str, str, str]] = []
    fails: list[bool] = [False]

    def add(status: str, check: str, detail: str) -> None:
        rows.append((status, check, detail))

    def fail() -> None:
        fails[0] = True

    if sys.version_info >= (3, 8):
        add("ok", "Python", f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}")
    else:
        add("fail", "Python", f"need 3.8+, got {sys.version_info}")
        fail()

    add("ok" if script.is_file() else "fail", "Script", str(script))
    if not script.is_file():
        fail()

    if os.access(script, os.X_OK):
        add("ok", "Executable bit", "+x on this file (good for direct exec)")
    else:
        add("warn", "Executable bit", "no +x — openbuddy-launcher uses python3; OK")

    add("ok" if HAS_RICH else "warn", "rich", "installed" if HAS_RICH else "pip install rich (nicer panels)")

    tmx = shutil.which("tmux")
    add("ok" if tmx else "warn", "tmux", tmx or "not in PATH (no split-pane buddy)")

    bash = shutil.which("bash")
    add("ok" if bash else "warn", "bash", bash or "needed for openbuddy-wrap")

    npx = shutil.which("npx")
    add("ok" if npx else "warn", "npx / Node", npx or "optional (tokscale tokens/sync)")

    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        probe = STATE_DIR / ".openbuddy_write_probe"
        probe.write_text("ok", encoding="utf-8")
        probe.unlink(missing_ok=True)
        add("ok", "State directory", str(STATE_DIR))
    except OSError as e:
        add("fail", "State directory", f"{STATE_DIR} — {e}")
        fail()

    if CONFIG_FILE.is_file():
        try:
            json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
            add("ok", "config.json", str(CONFIG_FILE))
        except json.JSONDecodeError as e:
            add("fail", "config.json", f"invalid JSON: {e}")
            fail()
    else:
        add("info", "config.json", "optional (see docs/config.example.json)")

    here = script.parent
    for name in ("openbuddy-launcher", "openbuddy-wrap"):
        p = here / name
        add("ok" if p.is_file() else "warn", name, str(p) if p.is_file() else f"not next to openbuddy ({here})")

    local_ob = Path.home() / ".local" / "bin" / "openbuddy"
    if local_ob.is_file() or local_ob.is_symlink():
        try:
            same = local_ob.resolve() == script
            add("ok" if same else "warn", "~/.local/bin/openbuddy", str(local_ob.resolve()))
        except OSError:
            add("warn", "~/.local/bin/openbuddy", str(local_ob))
    else:
        add("info", "~/.local/bin/openbuddy", "not found (optional PATH shim)")

    if HAS_RICH:
        tbl = Table(title="\u2726 openbuddy doctor \u2726", show_lines=False)
        tbl.add_column(" ", style="dim", width=3)
        tbl.add_column("Check", style="bold")
        tbl.add_column("Detail")
        icon = {"ok": "[green]\u2713[/]", "warn": "[yellow]![/]", "fail": "[red]\u2717[/]", "info": "[cyan]i[/]"}
        for st, ck, det in rows:
            tbl.add_row(icon.get(st, "?"), ck, det)
        Console().print(Panel(tbl, border_style="bright_blue"))
    else:
        print("\n  \u2726 openbuddy doctor \u2726\n")
        sym = {"ok": "[OK]", "warn": "[!!]", "fail": "[XX]", "info": "[--]"}
        for st, ck, det in rows:
            print(f"  {sym.get(st, '  ')}  {ck}: {det}")
        print()

    if fails[0]:
        if HAS_RICH:
            Console().print("[red]Some checks failed. Fix the items marked \u2717.[/]")
        else:
            print("Some checks failed (see [XX] above).")
        return 1
    if HAS_RICH:
        Console().print("[dim]All required checks passed. Warnings are optional.[/]")
    return 0


def cmd_info(state: dict):
    stage  = get_stage_for_state(state)
    prog   = progress_points(state)
    is_egg = not state.get("hatched", False)
    ts     = state.get("tool_sessions", {})
    lt     = int(state.get("lifetime_tokens", 0) or 0)
    if HAS_RICH:
        c = Console()
        if is_egg:
            c.print(
                f"[bold white]Stage:[/] EGG  sessions {state['sessions']}/{EGG_HATCH_AT}  "
                f"tok {format_tokens(lt)}/{format_tokens(TOKENS_TO_HATCH)}"
            )
            lc = _lifetime_cost_usd(state)
            if lc > 0:
                c.print(f"[bold]Spend:[/]   {format_cost(lc)} (tokscale est., all-time)")
        else:
            creature = CREATURES[state["creature"]]
            c.print(f"[bold]Name:[/]   {creature['name']}  [{creature['rarity'].upper()}]")
            c.print(f"[bold]Stage:[/]  {stage}  (progress {prog}: sess {state['sessions']}, {format_tokens(lt)} tok)")
            lc = _lifetime_cost_usd(state)
            if lc > 0:
                c.print(f"[bold]Spend:[/]   {format_cost(lc)} (tokscale est., all-time)")
            if ts:
                c.print(f"[bold]Tools:[/]  {_tool_summary(state)}")
    else:
        if is_egg:
            print(f"Stage: EGG  sessions {state['sessions']}/{EGG_HATCH_AT}  tok {lt}/{TOKENS_TO_HATCH}")
        else:
            creature = CREATURES[state["creature"]]
            print(f"Name:  {creature['name']}  [{creature['rarity'].upper()}]")
            print(f"Stage: {stage}  (progress {prog}, {state['sessions']} sess, {lt} tok)")
            lc = _lifetime_cost_usd(state)
            if lc > 0:
                print(f"Spend: {format_cost(lc)} (tokscale est., all-time)")
            if ts:
                print(f"Tools: {_tool_summary(state)}")

def cmd_list():
    rarity_colors = {"common": "white", "rare": "bright_cyan", "legendary": "bright_yellow"}
    if HAS_RICH:
        c = Console()
        c.print("\n[bold]Available Creatures (10):[/]\n")
        for data in CREATURES.values():
            rc = rarity_colors[data["rarity"]]
            c.print(f"  [{rc}]{data['name']:12}[/]  [{rc}]{data['rarity'].upper():9}[/]  [dim]{data['title']}[/]")
        c.print()
    else:
        print("\nAvailable Creatures (10):\n")
        for data in CREATURES.values():
            print(f"  {data['name']:12}  {data['rarity'].upper():9}  {data['title']}")
        print()

def cmd_stats(state: dict):
    """Show session statistics dashboard."""
    daily = state.get("daily_log", {})
    ts    = state.get("tool_sessions", {})
    sessions = state["sessions"]
    created  = state.get("created_at", "")

    today_str = datetime.now().strftime("%Y-%m-%d")
    week_ago  = (datetime.now() - timedelta(days=7)).strftime("%Y-%m-%d")

    today_sessions = daily.get(today_str, {}).get("sessions", 0)
    week_sessions  = sum(
        v.get("sessions", 0) for d, v in daily.items() if d >= week_ago
    )
    streak = 0
    d = datetime.now()
    while True:
        ds = d.strftime("%Y-%m-%d")
        if ds in daily and daily[ds].get("sessions", 0) > 0:
            streak += 1
            d -= timedelta(days=1)
        else:
            break

    if HAS_RICH:
        c = Console()
        c.print()

        # Header
        creature = CREATURES.get(state.get("creature", ""), {})
        cname = creature.get("name", "???") if state.get("hatched") else "???"
        c.print(Panel(
            f"[bold]\U0001f4ca {cname}'s Stats Dashboard[/]",
            border_style="bright_cyan", width=44,
        ))

        # Overview
        tbl = Table(show_header=False, box=None, padding=(0, 2))
        tbl.add_column(style="bold")
        tbl.add_column(style="bright_white")
        tbl.add_row("Total sessions", str(sessions))
        lt_st = int(state.get("lifetime_tokens", 0) or 0)
        if lt_st > 0:
            tbl.add_row("Tokscale (stored)", format_tokens(lt_st))
        lc_st = _lifetime_cost_usd(state)
        if lc_st > 0:
            tbl.add_row("Tokscale est. spend", format_cost(lc_st))
        tbl.add_row("Progress pts", str(progress_points(state)))
        tbl.add_row("Today", str(today_sessions))
        tbl.add_row("This week", str(week_sessions))
        tbl.add_row("\U0001f525 Streak", f"{streak} day(s)")
        if created:
            try:
                age = (datetime.now() - datetime.fromisoformat(created)).days
                tbl.add_row("Age", f"{age} day(s)")
            except ValueError:
                pass
        c.print(tbl)

        # Tool breakdown
        if ts:
            c.print("\n[bold]Sessions by tool:[/]")
            max_val = max(ts.values()) if ts else 1
            for tool, count in sorted(ts.items(), key=lambda x: -x[1]):
                bar_len = round((count / max_val) * 16)
                bar = "\u2588" * bar_len + "\u2591" * (16 - bar_len)
                c.print(f"  {tool:12} {bar} {count}")

        # Weekly activity (last 7 days)
        c.print("\n[bold]Last 7 days:[/]")
        days_line = "  "
        bars_line = "  "
        for i in range(6, -1, -1):
            d = datetime.now() - timedelta(days=i)
            ds = d.strftime("%Y-%m-%d")
            dn = d.strftime("%a")[:2]
            cnt = daily.get(ds, {}).get("sessions", 0)
            if cnt == 0:
                block = "\u2591"
            elif cnt <= 2:
                block = "\u2592"
            elif cnt <= 5:
                block = "\u2593"
            else:
                block = "\u2588"
            days_line += f" {dn}"
            bars_line += f"  {block}"
        c.print(days_line)
        c.print(bars_line)
        c.print()
    else:
        print(f"\n{'=' * 40}")
        print(f"  \U0001f4ca Stats Dashboard")
        print(f"{'=' * 40}")
        lt_st = int(state.get("lifetime_tokens", 0) or 0)
        print(f"  Total:   {sessions} sessions  progress {progress_points(state)}")
        if lt_st > 0:
            print(f"  Tokscale stored: {lt_st}")
        lc_st = _lifetime_cost_usd(state)
        if lc_st > 0:
            print(f"  Tokscale est. spend: {format_cost(lc_st)}")
        print(f"  Today:   {today_sessions}")
        print(f"  Week:    {week_sessions}")
        print(f"  Streak:  {streak} day(s)")
        if ts:
            print(f"\n  Sessions by tool:")
            for tool, count in sorted(ts.items(), key=lambda x: -x[1]):
                print(f"    {tool:12} {count}")
        print(f"{'=' * 40}\n")

def cmd_tokens(state: dict, apply_sync: bool = False):
    """Show tokscale token usage; with apply_sync, merge all-time totals into progress (level-up)."""
    creature = CREATURES.get(state.get("creature", ""), {})
    cname = creature.get("name", "???") if state.get("hatched") else "???"

    if HAS_RICH:
        Console().print(f"\n[bold]\U0001f50d Fetching token data from tokscale...[/]")

    data = get_tokscale_data("--today")

    if data is None:
        if not _resolve_npx():
            msg = (
                "npx not found — install Node.js or fix PATH (IDE/agent shells often omit Node). "
                "Try the same command in a terminal where `npx tokscale --help` works."
            )
        else:
            msg = (
                "tokscale failed (non-zero exit, bad JSON, or empty stdout). "
                "Check local data: npx tokscale@latest --json --no-spinner --today"
            )
        if HAS_RICH:
            Console().print(f"[dim]{msg}[/]")
        else:
            print(f"  {msg}")
        return

    p = parse_tokscale_report(data)
    total_input = p["total_input"]
    total_output = p["total_output"]
    total_tokens = p["total_xp"]
    total_cost = p["total_cost"]
    platforms = p["platforms"]

    if HAS_RICH:
        c = Console()
        if total_tokens > 500_000:
            mood = "\U0001f92f"
            react = random.choice(creature.get("quotes", {}).get("fed", ["*stuffed*"]))
        elif total_tokens > 100_000:
            mood = "\U0001f60b"
            react = random.choice(creature.get("quotes", {}).get("fed", ["*well fed*"]))
        elif total_tokens > 0:
            mood = "\U0001f642"
            react = "A light snack of tokens..."
        else:
            mood = "\U0001f634"
            react = "No tokens today... hungry..."

        c.print(Panel(
            f"[bold]{mood} {cname}'s Token Report (Today)[/]",
            border_style="bright_yellow", width=44,
        ))

        tbl = Table(show_header=False, box=None, padding=(0, 2))
        tbl.add_column(style="bold")
        tbl.add_column(style="bright_white")
        tbl.add_row("\U0001f4e5 Input",  format_tokens(total_input))
        tbl.add_row("\U0001f4e4 Output", format_tokens(total_output))
        if p.get("total_reasoning"):
            tbl.add_row("\U0001f9e0 Reasoning", format_tokens(p["total_reasoning"]))
        tbl.add_row("\U0001f4ca Total (XP)",  format_tokens(total_tokens))
        if total_cost > 0:
            tbl.add_row("\U0001f4b0 Cost", format_cost(total_cost))
        c.print(tbl)

        if platforms:
            c.print("\n[bold]By client:[/]")
            max_val = max(platforms.values()) if platforms else 1
            for plat, tok in sorted(platforms.items(), key=lambda x: -x[1]):
                bar_len = round((tok / max_val) * 14)
                bar = "\u2588" * bar_len + "\u2591" * (14 - bar_len)
                c.print(f"  {plat:12} {bar} {format_tokens(tok)}")

        c.print(f'\n  \U0001f4ac [italic]"{react}"[/]')
        c.print()
    else:
        print(f"\n  Today — in {format_tokens(total_input)} / out {format_tokens(total_output)} / total {format_tokens(total_tokens)}")

    if apply_sync:
        if HAS_RICH:
            Console().print("[bold]\U0001f504 Syncing all-time totals into buddy progress...[/]")
        all_d = get_tokscale_data()
        if all_d is None:
            msg = (
                "Could not fetch all-time tokscale JSON. "
                + (
                    "npx not found (Node not on PATH)."
                    if not _resolve_npx()
                    else "Run: npx tokscale@latest --json --no-spinner"
                )
            )
            (Console().print(f"[yellow]{msg}[/]") if HAS_RICH else print(msg))
            return
        life = parse_tokscale_report(all_d)
        apply_tokscale_to_state(
            state, life["total_xp"], total_cost=life.get("total_cost"), run_animations=True
        )
        if HAS_RICH:
            sp = format_cost(_lifetime_cost_usd(state)) if _lifetime_cost_usd(state) > 0 else "—"
            Console().print(
                f"[dim]Stored lifetime XP: {format_tokens(state['lifetime_tokens'])} "
                f"(progress {progress_points(state)}), est. spend {sp}.[/]\n"
            )
        else:
            lc = _lifetime_cost_usd(state)
            extra = f", spend {format_cost(lc)}" if lc > 0 else ""
            print(f"  Synced: {state['lifetime_tokens']} tok → progress {progress_points(state)}{extra}")
        render(state, message=get_quote(state))


def cmd_sync(state: dict, quiet: bool = False):
    """Fetch tokscale all-time usage and update level progress only (no today table)."""
    if not quiet and HAS_RICH:
        Console().print("[bold]\U0001f504 Syncing tokscale (all-time) → openbuddy...[/]")
    all_d = get_tokscale_data()
    if all_d is None:
        if quiet:
            return
        msg = (
            "tokscale sync failed. "
            + (
                "npx not found (Node not on PATH)."
                if not _resolve_npx()
                else "Try: npx tokscale@latest --json --no-spinner — check local session data."
            )
        )
        (Console().print(f"[yellow]{msg}[/]") if HAS_RICH else print(msg))
        return
    life = parse_tokscale_report(all_d)
    apply_tokscale_to_state(
        state, life["total_xp"], total_cost=life.get("total_cost"), run_animations=not quiet
    )
    if quiet:
        return
    lc = _lifetime_cost_usd(state)
    spend_s = f", est. spend {format_cost(lc)}" if lc > 0 else ""
    if HAS_RICH:
        Console().print(
            f"[green]OK[/] — stored {format_tokens(state['lifetime_tokens'])}, "
            f"progress {progress_points(state)}{spend_s}.\n"
        )
    else:
        print(f"OK — {state['lifetime_tokens']} tok, progress {progress_points(state)}{spend_s}")
    render(state, message=get_quote(state))

# ── Codex CLI hooks (SessionStart additionalContext — inside Codex, not a side window) ──

CODEX_HOOKS_FILE = Path.home() / ".codex" / "hooks.json"


def format_codex_additional_context(state: dict) -> str:
    """Short text injected into Codex as developer additionalContext (SessionStart hook)."""
    lt = int(state.get("lifetime_tokens", 0) or 0)
    cost_ln = _codex_context_cost_line(state)
    if not state.get("hatched"):
        return (
            f"[openbuddy] Egg — sessions {state.get('sessions', 0)}/{EGG_HATCH_AT}, "
            f"tokens {format_tokens(lt)}/{format_tokens(TOKENS_TO_HATCH)} (tokscale).\n"
            f"{cost_ln}\n"
            f"CLI: openbuddy show  |  openbuddy sync  |  openbuddy codex-install-hook"
        )
    c = CREATURES[state["creature"]]
    st = get_stage_for_state(state)
    prog = progress_points(state)
    nxt = get_next_stage_at(prog)
    nxt_s = f" next->{nxt}" if nxt else ""
    tools = _tool_summary(state)
    tools_s = f"\nTools: {tools}" if tools else ""
    return (
        f"[openbuddy] {c['name']} — {st} — progress {prog}{nxt_s}\n"
        f"{c['title']}{tools_s}\n"
        f"{cost_ln}\n"
        f"CLI: openbuddy show  |  openbuddy sync"
    )


def cmd_codex_hook_session_start() -> None:
    """Codex SessionStart hook: JSON on stdout with additionalContext."""
    try:
        sys.stdin.read()
    except Exception:
        pass
    state = load_state()
    # Pull all-time $ from tokscale when missing (stdout must stay JSON-only — no animations)
    if _resolve_npx() and _lifetime_cost_usd(state) <= 0:
        fresh = get_tokscale_data(timeout_sec=30)
        if fresh:
            life = parse_tokscale_report(fresh)
            apply_tokscale_to_state(
                state,
                life["total_xp"],
                total_cost=life.get("total_cost"),
                run_animations=False,
            )
    ctx = format_codex_additional_context(state)
    print(
        json.dumps(
            {
                "hookSpecificOutput": {
                    "hookEventName": "SessionStart",
                    "additionalContext": ctx,
                }
            },
            ensure_ascii=False,
        )
    )


def cmd_codex_hook_stop() -> None:
    """Codex Stop hook: +1 session per finished turn (optional; do not use with codex PATH wrapper)."""
    try:
        sys.stdin.read()
    except Exception:
        pass
    state = load_state()
    cmd_session(state, "codex", silent=True, hook_mode=True)
    print(json.dumps({"continue": True}))


def _hook_cmd_has_openbuddy_marker(obj) -> bool:
    """True if serialized hook mentions codex-hook-session-start."""
    try:
        return "codex-hook-session-start" in json.dumps(obj)
    except (TypeError, ValueError):
        return False


def cmd_codex_install_hook() -> None:
    """Merge SessionStart hook into ~/.codex/hooks.json (absolute openbuddy path)."""
    CODEX_HOOKS_FILE.parent.mkdir(parents=True, exist_ok=True)
    ob = Path(__file__).resolve()
    py = sys.executable
    argv_cmd = [str(py), str(ob), "codex-hook-session-start"]

    # OpenAI docs shape: { "hooks": { "SessionStart": [ { "matcher", "hooks": [...] } ] } } }
    entry_official = {
        "matcher": "startup|resume",
        "hooks": [
            {
                "type": "command",
                "command": (
                    subprocess.list2cmdline(argv_cmd)
                    if IS_WINDOWS
                    else f"{shlex.quote(py)} {shlex.quote(str(ob))} codex-hook-session-start"
                ),
                "statusMessage": "openbuddy",
            }
        ],
    }

    # Alternate shape (seen in the wild): { "hooks": [ { "event": "SessionStart", "handler": {...} } ] }
    entry_array = {
        "event": "SessionStart",
        "handler": {
            "command": argv_cmd,
            "statusMessage": "openbuddy",
        },
    }

    data: dict = {}
    if CODEX_HOOKS_FILE.exists():
        try:
            data = json.loads(CODEX_HOOKS_FILE.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            print(f"warning: could not parse {CODEX_HOOKS_FILE}, resetting hooks key", file=sys.stderr)
            data = {}

    hooks = data.get("hooks")

    if isinstance(hooks, list):
        for item in hooks:
            if _hook_cmd_has_openbuddy_marker(item):
                print(f"Already configured (array hooks): {CODEX_HOOKS_FILE}")
                _codex_install_hook_footer()
                return
        hooks.append(entry_array)
        data["hooks"] = hooks

    elif isinstance(hooks, dict):
        ss = hooks.setdefault("SessionStart", [])
        if not isinstance(ss, list):
            ss = []
            hooks["SessionStart"] = ss
        for group in ss:
            for h in group.get("hooks", []):
                if "codex-hook-session-start" in (h.get("command") or ""):
                    print(f"Already configured: {CODEX_HOOKS_FILE}")
                    _codex_install_hook_footer()
                    return
        ss.append(entry_official)
        data["hooks"] = hooks

    else:
        data["hooks"] = {"SessionStart": [entry_official]}

    CODEX_HOOKS_FILE.write_text(json.dumps(data, indent=2), encoding="utf-8")
    print(f"Wrote: {CODEX_HOOKS_FILE}")
    _codex_install_hook_footer()


def _codex_install_hook_footer() -> None:
    cfg = Path.home() / ".codex" / "config.toml"
    if cfg.is_file() and "codex_hooks" in cfg.read_text(encoding="utf-8", errors="replace"):
        print("config.toml: codex_hooks already present.")
    else:
        print("\nAdd to ~/.codex/config.toml:\n[features]\ncodex_hooks = true\n")
    print("Note: Codex hooks may be disabled on Windows (OpenAI); WSL/macOS/Linux often work.")
    print(
        "SessionStart only injects context; for +1 sessions without tmux use: "
        "openbuddy codex-setup --write-wrapper"
    )


def _find_codex_real_binary() -> Optional[Path]:
    """Resolve codex on PATH, skipping ~/.local/bin (often our wrapper)."""
    local_bin = (Path.home() / ".local" / "bin").resolve()
    for dir_path in os.environ.get("PATH", "").split(os.pathsep):
        if not (dir_path or "").strip():
            continue
        try:
            d = Path(dir_path).resolve()
        except OSError:
            continue
        if d == local_bin:
            continue
        for name in ("codex", "codex.exe"):
            p = Path(dir_path) / name
            if not p.is_file():
                continue
            if IS_WINDOWS:
                if p.suffix.lower() in (".exe", ".cmd") or os.access(p, os.X_OK):
                    return p.resolve()
            elif os.access(p, os.X_OK):
                return p.resolve()
    for fp in ("/usr/bin/codex", "/usr/local/bin/codex"):
        p = Path(fp)
        if p.is_file() and os.access(p, os.X_OK):
            return p.resolve()
    return None


def cmd_codex_setup(args: list[str]) -> None:
    """Install SessionStart hook + optionally write a minimal codex shim (no tmux / launcher)."""
    write_wrapper = "--write-wrapper" in args or "-w" in args
    real_override: Optional[Path] = None
    i = 0
    while i < len(args):
        if args[i] == "--codex-path" and i + 1 < len(args):
            real_override = Path(args[i + 1]).expanduser().resolve()
            i += 2
            continue
        i += 1
    if real_override is None:
        e = os.environ.get("OPENBUDDY_CODEX_REAL")
        if e:
            real_override = Path(e).expanduser().resolve()

    cmd_codex_install_hook()

    if HAS_RICH:
        Console().print(
            "\n[bold cyan]Codex hooks mode[/] — buddy state is injected as [bold]additionalContext[/] "
            "at session start (no tmux split).\n"
        )
    else:
        print("\nCodex hooks mode: SessionStart → additionalContext in the model (no tmux).\n")

    real: Optional[Path] = real_override
    if real is not None and not real.is_file():
        print(f"Not a file: {real}", file=sys.stderr)
        sys.exit(1)
    if real is None:
        real = _find_codex_real_binary()
    if real is None:
        if write_wrapper:
            print(
                "Could not find a real codex binary (skipped ~/.local/bin). "
                "Set OPENBUDDY_CODEX_REAL or use: openbuddy codex-setup --write-wrapper --codex-path /path/to/codex",
                file=sys.stderr,
            )
            sys.exit(1)
        print(
            "\n(Optional) Could not detect codex outside ~/.local/bin — "
            "when you want a minimal wrapper, run with --write-wrapper --codex-path …\n"
        )
        return

    print(f"Real codex binary: {real}")

    if not write_wrapper:
        print("\nTo also count sessions without tmux, run:")
        print("  openbuddy codex-setup --write-wrapper")
        print("(backs up ~/.local/bin/codex if present)\n")
        return

    dest = Path.home() / ".local" / "bin" / "codex"
    dest.parent.mkdir(parents=True, exist_ok=True)
    if dest.exists() or dest.is_symlink():
        bak = dest.with_name(f"codex.bak.{int(time.time())}.openbuddy")
        try:
            shutil.move(str(dest), str(bak))
            print(f"Backed up previous {dest} → {bak}")
        except OSError as e:
            print(f"Could not back up {dest}: {e}", file=sys.stderr)
            sys.exit(1)

    real_s = shlex.quote(str(real))
    body = f"""#!/usr/bin/env bash
# openbuddy: Codex hooks mode — no tmux. Regenerate: openbuddy codex-setup --write-wrapper
set -euo pipefail
OPENBUDDY_BIN="${{OPENBUDDY_BIN:-$HOME/.local/bin/openbuddy}}"
REAL_BIN={real_s}
[[ -x "$OPENBUDDY_BIN" ]] || exec "$REAL_BIN" "$@"
[[ -z "${{OPENBUDDY_WRAPPED:-}}" ]] || exec "$REAL_BIN" "$@"
export OPENBUDDY_WRAPPED=1
"$OPENBUDDY_BIN" session codex --silent
exec "$REAL_BIN" "$@"
"""
    dest.write_text(body, encoding="utf-8")
    try:
        dest.chmod(dest.stat().st_mode | 0o111)
    except OSError:
        pass
    print(f"Wrote minimal wrapper: {dest}")
    if HAS_RICH:
        Console().print("[dim]Ensure ~/.local/bin is first on PATH. Run codex in a terminal with hooks enabled.[/]")
    else:
        print("Ensure ~/.local/bin is first on PATH.")


# ── Main ──────────────────────────────────────────────────────────────────────

USAGE = """\
Usage: openbuddy [command] [tool]

Commands:
  show            Show your buddy (default)
  session [tool]  Increment session count, optionally tag tool name
  watch           Live refresh mode (for tmux split pane; interval: OPENBUDDY_WATCH_INTERVAL)
  stats           Show session statistics dashboard
  wrap-preset [ai] Run openbuddy-wrap --preset (gemini/재미나이, codex, opencode, … — needs bash / Git Bash)
  codex-install-hook   Add Codex SessionStart hook → buddy summary inside Codex (not a side panel)
  codex-setup          Codex hooks workflow: install hook; optional --write-wrapper (minimal codex shim, no tmux)
  codex-hook-session-start   For hooks.json only (reads stdin, prints SessionStart JSON)
  codex-hook-stop          Optional: +1 session each Codex turn (use instead of wrapper, not both)
  tokens          Today's token usage via tokscale (npx tokscale --today --json)
  tokens --apply  Same as tokens, then sync all-time tokscale totals into level progress
  sync            Only sync all-time tokscale → progress (hatch / evolve from tokens)
  sync --quiet    Same, no banner/panel (for background / wrappers)
  reset           Delete current buddy and start a new egg
  info            Show brief buddy info
  list            List all creature types
  doctor, check   Environment diagnostics (Python, tmux, paths, optional deps)

Progress = max(sessions, lifetime_tokens // 100000). Egg hatches at 3 sessions OR 250k tok (synced).
Env: OPENBUDDY_AUTO_SYNC, TOKENS_PER_PROGRESS_UNIT, TOKENS_TO_HATCH.
Wrapper/tmux: OPENBUDDY_TMUX_PCT (default 9%), OPENBUDDY_TMUX_V_PCT (vertical; default 10% if unset), OPENBUDDY_TMUX_VERTICAL, OPENBUDDY_COMPACT. Launcher: OPENBUDDY_TMUX_COLS (default 16 cells).
UI: Default is compact (space-saving). OPENBUDDY_FULL_UI=1 restores large panel when the terminal is wide (or set full_ui in config.json).
Watch: OPENBUDDY_WATCH_INTERVAL (seconds; default 6; clamp 0.5–3600). OPENBUDDY_COMPACT_THRESHOLD (cols; used only with FULL_UI).
Config: ~/.config/openbuddy/config.json optional keys: watch_interval, compact_auto_threshold, full_ui (env overrides).

Examples:
  openbuddy
  openbuddy codex-install-hook
  openbuddy codex-setup
  openbuddy codex-setup --write-wrapper
  openbuddy wrap-preset
  openbuddy session codex
  openbuddy stats
  openbuddy tokens
  openbuddy tokens --apply
  openbuddy sync
  openbuddy watch
  openbuddy doctor
"""


def cmd_wrap_preset(args: list[str]) -> None:
    """Delegate to openbuddy-wrap --preset ai (Gemini, Codex, OpenCode, Claude, …)."""
    preset = "ai"
    if len(args) > 1 and not str(args[1]).startswith("-"):
        preset = args[1]
    here = Path(__file__).resolve().parent
    wrap = here / "openbuddy-wrap"
    if not wrap.is_file():
        wrap = Path.home() / ".local/bin/openbuddy-wrap"
    if not wrap.is_file():
        print("openbuddy-wrap not found next to openbuddy or in ~/.local/bin", file=sys.stderr)
        sys.exit(1)
    bash = shutil.which("bash")
    if not bash:
        print(
            "bash not in PATH (install Git Bash). Or run: openbuddy-wrap-preset.cmd",
            file=sys.stderr,
        )
        sys.exit(1)
    sys.exit(subprocess.call([bash, str(wrap), "--preset", preset]))


def main():
    args = sys.argv[1:]
    cmd  = args[0] if args else "show"

    if cmd in ("-h", "--help", "help"):
        print(USAGE)
        return
    if cmd == "wrap-preset":
        cmd_wrap_preset(args)
        return
    if cmd == "codex-install-hook":
        cmd_codex_install_hook()
        return
    if cmd == "codex-setup":
        cmd_codex_setup(args[1:])
        return
    if cmd == "codex-hook-session-start":
        cmd_codex_hook_session_start()
        return
    if cmd == "codex-hook-stop":
        cmd_codex_hook_stop()
        return
    if cmd == "reset":
        cmd_reset()
        return
    if cmd == "list":
        cmd_list()
        return
    if cmd in ("doctor", "check"):
        sys.exit(cmd_doctor())

    state = load_state()

    if cmd == "session":
        tool    = args[1] if len(args) > 1 else "unknown"
        silent  = "--silent" in args
        cmd_session(state, tool, silent=silent)
    elif cmd == "watch":
        cmd_watch(state)
    elif cmd == "info":
        cmd_info(state)
    elif cmd == "stats":
        cmd_stats(state)
    elif cmd == "tokens":
        cmd_tokens(state, apply_sync="--apply" in args[1:])
    elif cmd == "sync":
        cmd_sync(state, quiet="--quiet" in args[1:] or "-q" in args[1:])
    else:
        cmd_show(state)


if __name__ == "__main__":
    main()

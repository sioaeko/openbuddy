#!/usr/bin/env python3
"""
openbuddy: A Tamagotchi-like companion for any CLI coding tool.
State stored in ~/.config/openbuddy/state.json
"""

import json
import os
from typing import Optional
import shlex
import shutil
import sys
import time
import random
import subprocess
from datetime import datetime, timedelta
from pathlib import Path

# Fix encoding on Windows (cp949/cp932 can't handle Unicode symbols)
if sys.platform == "win32" and sys.stdout.encoding and sys.stdout.encoding.lower() not in ("utf-8", "utf8"):
    sys.stdout.reconfigure(encoding="utf-8", errors="replace")
    sys.stderr.reconfigure(encoding="utf-8", errors="replace")

IS_WINDOWS = sys.platform == "win32"

try:
    from rich.console import Console
    from rich.panel import Panel
    from rich.text import Text
    from rich.table import Table
    HAS_RICH = True
except ImportError:
    HAS_RICH = False

STATE_DIR  = Path.home() / ".config" / "openbuddy"
STATE_FILE = STATE_DIR / "state.json"
CONFIG_FILE = STATE_DIR / "config.json"

# Optional JSON next to state.json — env vars override these keys when set.
_user_config_cache: Optional[dict] = None


def _user_config() -> dict:
    """~/.config/openbuddy/config.json — cached for process lifetime."""
    global _user_config_cache
    if _user_config_cache is not None:
        return _user_config_cache
    loaded: dict = {}
    if CONFIG_FILE.is_file():
        try:
            data = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
            if isinstance(data, dict):
                loaded = data
        except (json.JSONDecodeError, OSError):
            pass
    _user_config_cache = loaded
    return _user_config_cache


# Legacy migration paths
LEGACY_PATHS = [
    Path.home() / ".codex" / "buddy.json",
    Path.home() / ".config" / "anygochi" / "state.json",
]


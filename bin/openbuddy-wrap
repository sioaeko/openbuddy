#!/usr/bin/env bash
# openbuddy-wrap: Create an openbuddy-enabled wrapper for any CLI coding tool.
#
# Usage:
#   openbuddy-wrap <toolname>          # wrap a tool in PATH
#   openbuddy-wrap <toolname> /path    # wrap a specific binary
#   openbuddy-wrap --list              # list currently wrapped tools
#   openbuddy-wrap --remove <toolname> # remove a wrapper
#
# Example:
#   openbuddy-wrap codex
#   openbuddy-wrap aider
#   openbuddy-wrap gh

set -euo pipefail

LOCAL_BIN="$HOME/.local/bin"
OPENBUDDY="$LOCAL_BIN/openbuddy"

# ── Helpers ───────────────────────────────────────────────────────────────────

die()  { echo "error: $*" >&2; exit 1; }
info() { echo "  $*"; }

require_openbuddy() {
    [[ -x "$OPENBUDDY" ]] || die "openbuddy not found at $OPENBUDDY"
}

# Find the real binary for a tool name, skipping wrappers in LOCAL_BIN
find_real_binary() {
    local tool="$1"
    # Walk PATH entries; skip our own LOCAL_BIN wrapper if present
    while IFS= read -r -d ':' dir; do
        [[ -z "$dir" ]] && continue
        local candidate="$dir/$tool"
        if [[ -x "$candidate" && "$dir" != "$LOCAL_BIN" ]]; then
            echo "$candidate"
            return 0
        fi
    done <<< "${PATH}:"
    return 1
}

# ── Commands ──────────────────────────────────────────────────────────────────

do_wrap() {
    local tool="$1"
    local real_bin="${2:-}"

    require_openbuddy

    # Resolve real binary
    if [[ -z "$real_bin" ]]; then
        real_bin="$(find_real_binary "$tool")" \
            || die "could not find '$tool' in PATH (excluding $LOCAL_BIN)"
    else
        [[ -x "$real_bin" ]] || die "'$real_bin' is not executable"
    fi

    local wrapper="$LOCAL_BIN/$tool"

    # Safety: don't wrap openbuddy itself or openbuddy-wrap
    [[ "$tool" == "openbuddy" || "$tool" == "openbuddy-wrap" ]] \
        && die "cannot wrap openbuddy itself"

    # Warn if already wrapped
    if [[ -f "$wrapper" ]]; then
        # Check if it's one of ours
        if head -3 "$wrapper" 2>/dev/null | grep -q "^# openbuddy wrapper for:"; then
            echo "  '$tool' is already wrapped. Overwriting..."
        else
            die "'$wrapper' exists and is not an openbuddy wrapper. Move it first."
        fi
    fi

    mkdir -p "$LOCAL_BIN"

    cat > "$wrapper" <<WRAPPER
#!/usr/bin/env bash
# openbuddy wrapper for: $tool
# real binary: $real_bin
# generated by: openbuddy-wrap

set -euo pipefail

OPENBUDDY_BIN="$OPENBUDDY"
REAL_BIN="$real_bin"

# Helper for robust TTY flushing
_flush_stdin() {
    # 1. Wait a moment for terminal focus events/resizes to settle
    sleep 0.5
    # 2. Use python for raw TTY flushing (more reliable than shell read)
    python3 -c 'import sys, termios; termios.tcflush(sys.stdin, termios.TCIFLUSH)' 2>/dev/null || true
    # 3. Final safety drain
    while read -r -t 0.05 -n 10000 _trash; do :; done 2>/dev/null || true
}

if [[ -x "\$OPENBUDDY_BIN" && -z "\${OPENBUDDY_WRAPPED:-}" ]]; then
    export OPENBUDDY_WRAPPED=1

    # Calculate pane widths
    _cols="\$(tput cols 2>/dev/null || echo 80)"
    _lines="\$(tput lines 2>/dev/null || echo 24)"
    _main=\$(( _cols - 31 ))
    [[ \$_main -lt 40 ]] && _main=\$_cols

    if [[ -n "\${TMUX:-}" ]]; then
        # Already in tmux: split window for buddy
        "\$OPENBUDDY_BIN" session "$tool" --silent 2>/dev/null || true
        if [[ \$_main -lt \$_cols ]]; then
            tmux split-window -h -b -d -l 31 "\$OPENBUDDY_BIN watch"
        fi
        
        # AGGRESSIVE FLUSH: Resolves auto-submitted "" input
        _flush_stdin
        
        exec "\$REAL_BIN" "\$@"

    elif command -v tmux &>/dev/null; then
        # Not in tmux: build layout in detached session
        "\$OPENBUDDY_BIN" session "$tool" --silent 2>/dev/null || true
        _sess="openbuddy-\$\$"
        
        tmux new-session -d -s "\$_sess" -x "\$_cols" -y "\$_lines" "\$OPENBUDDY_BIN watch"
        tmux split-window -h -b -l "\$_main" -t "\$_sess" \\
            "export OPENBUDDY_WRAPPED=1; \\
             # Re-define flush helper inside the pane \\
             _flush_stdin() { sleep 0.6; python3 -c 'import sys, termios; termios.tcflush(sys.stdin, termios.TCIFLUSH)' 2>/dev/null || true; while read -r -t 0.05 -n 10000 _trash; do :; done 2>/dev/null || true; }; \\
             _flush_stdin; \\
             \$REAL_BIN \$(printf '%q ' \"\$@\"); echo; \$OPENBUDDY_BIN show; read -rsp '[press enter to close]'"
        exec tmux attach-session -t "\$_sess"

    else
        # No tmux: regular execution
        "\$OPENBUDDY_BIN" session "$tool" --silent 2>/dev/null || true
        "\$REAL_BIN" "\$@"
        _exit=\$?
        "\$OPENBUDDY_BIN" show 2>/dev/null || true
        exit \$_exit
    fi
else
    exec "\$REAL_BIN" "\$@"
fi
WRAPPER

    chmod +x "$wrapper"

    # On Windows (MSYS/Git Bash), also generate a .cmd wrapper
    if [[ "$(uname -s)" == MINGW* || "$(uname -s)" == MSYS* ]]; then
        local win_wrapper="$LOCAL_BIN/$tool.cmd"
        local python_exe
        python_exe="$(cygpath -w "$(command -v python 2>/dev/null || command -v python3 2>/dev/null)")" || true
        local openbuddy_win
        openbuddy_win="$(cygpath -w "$OPENBUDDY")" || true
        local node_entry=""
        local npm_root
        npm_root="$(npm root -g 2>/dev/null)" || true
        if [[ -n "$npm_root" ]]; then
            local real_cmd="$LOCAL_BIN/../AppData/Roaming/npm/$tool.cmd"
            [[ -f "$real_cmd" ]] || real_cmd="$(cygpath -u "$npm_root")/../$tool.cmd"
            if [[ -f "$real_cmd" ]]; then
                node_entry="$(grep -oP '(?<=node_modules\\\\)[^"]+' "$real_cmd" 2>/dev/null | head -1)" || true
            fi
        fi
        local run_line
        if [[ -n "$node_entry" ]]; then
            local npm_root_win
            npm_root_win="$(cygpath -w "$npm_root")" || true
            run_line="node \"$npm_root_win\\$node_entry\" %*"
        else
            local real_bin_win
            real_bin_win="$(cygpath -w "$real_bin")" || true
            run_line="\"$real_bin_win\" %*"
        fi

        cat > "$win_wrapper" <<CMDWRAPPER
@echo off
chcp 65001 >nul 2>nul
set PYTHONIOENCODING=utf-8
if defined OPENBUDDY_WRAPPED goto :run
set OPENBUDDY_WRAPPED=1
"$python_exe" "$openbuddy_win" session $tool --silent 2>nul
powershell -NoProfile -Command "\$env:PYTHONIOENCODING='utf-8'; Start-Process -FilePath '\$env:USERPROFILE\\AppData\\Local\\Programs\\Python\\Python310\\python.exe' -ArgumentList '\$env:USERPROFILE\\.local\\bin\\openbuddy','watch'"
:run
$run_line
CMDWRAPPER
        echo "  ✓ Created Windows wrapper: $win_wrapper"
    fi

    echo "  ✓ Wrapped '$tool'"
    echo "    wrapper : $wrapper"
    echo "    real    : $real_bin"
    echo ""
    echo "  Run 'openbuddy session $tool' is called automatically on each launch."
    echo "  Your buddy is at: $OPENBUDDY"
}

do_remove() {
    local tool="$1"
    local wrapper="$LOCAL_BIN/$tool"
    [[ -f "$wrapper" ]] || die "no wrapper found at $wrapper"
    head -3 "$wrapper" 2>/dev/null | grep -q "^# openbuddy wrapper for:" \
        || die "'$wrapper' doesn't look like an openbuddy wrapper"
    rm "$wrapper"
    [[ -f "$wrapper.cmd" ]] && rm "$wrapper.cmd"
    echo "  ✓ Removed wrapper for '$tool'"
}

do_list() {
    echo ""
    echo "  Wrapped tools in $LOCAL_BIN:"
    echo ""
    local found=0
    for f in "$LOCAL_BIN"/*; do
        [[ -f "$f" ]] || continue
        [[ "$f" == *.cmd ]] && continue
        if head -3 "$f" 2>/dev/null | grep -q "^# openbuddy wrapper for:"; then
            local tool
            tool="$(basename "$f")"
            local real
            real="$(grep "^# real binary:" "$f" | cut -d: -f2- | xargs)"
            local suffix=""
            [[ -f "$f.cmd" ]] && suffix=" (+.cmd)"
            printf "    %-16s → %s%s\n" "$tool" "${real:-unknown}" "$suffix"
            found=1
        fi
    done
    [[ $found -eq 0 ]] && echo "    (none yet — run: openbuddy-wrap <toolname>)"
    echo ""
}

# ── Main ──────────────────────────────────────────────────────────────────────

USAGE="Usage: openbuddy-wrap <toolname> [/path/to/real/binary]
       openbuddy-wrap --list
       openbuddy-wrap --remove <toolname>

Examples:
  openbuddy-wrap codex
  openbuddy-wrap aider
  openbuddy-wrap gh /usr/bin/gh
  openbuddy-wrap --list
  openbuddy-wrap --remove aider
"

case "${1:-}" in
    ""|"-h"|"--help"|"help")
        echo "$USAGE" ;;
    "--list"|"list")
        do_list ;;
    "--remove"|"remove")
        [[ -n "${2:-}" ]] || die "specify a tool name to remove"
        do_remove "$2" ;;
    -*)
        die "unknown option: $1" ;;
    *)
        do_wrap "$1" "${2:-}" ;;
esac

#!/usr/bin/env bash
# openbuddy-wrap: Create an openbuddy-enabled wrapper for any CLI coding tool.
#
# Usage:
#   openbuddy-wrap <toolname>          # wrap a tool in PATH
#   openbuddy-wrap <toolname> /path    # wrap a specific binary
#   openbuddy-wrap --list              # list currently wrapped tools
#   openbuddy-wrap --remove <toolname> # remove a wrapper
#
# Example:
#   openbuddy-wrap codex
#   openbuddy-wrap aider
#   openbuddy-wrap gh
#
# Optional env (runtime, when using generated wrappers):
#   OPENBUDDY_NO_TMUX=1          — skip auto-spawned tmux session; run tool in current tty, then openbuddy show
#   OPENBUDDY_TMUX_PCT=22        — width % for the buddy pane (tmux split -p)
#   OPENBUDDY_NO_PAUSE_AFTER=1   — do not wait for Enter after openbuddy show (non-tmux / after tool exits)
#   OPENBUDDY_AUTO_SYNC=1        — after session --silent, background: openbuddy sync --quiet (tokscale → progress)
#   OPENBUDDY_POPUP_WATCH=1      — Windows .cmd only: also open a separate watch window (legacy behavior)

set -euo pipefail

LOCAL_BIN="$HOME/.local/bin"
OPENBUDDY="$LOCAL_BIN/openbuddy"

# ── Helpers ───────────────────────────────────────────────────────────────────

die()  { echo "error: $*" >&2; exit 1; }
info() { echo "  $*"; }

require_openbuddy() {
    [[ -x "$OPENBUDDY" ]] || die "openbuddy not found at $OPENBUDDY"
}

# Find the real binary for a tool name, skipping wrappers in LOCAL_BIN
# Also checks tool.exe / tool.cmd (npm global on Windows / Git Bash)
find_real_binary() {
    local tool="$1"
    while IFS= read -r -d ':' dir; do
        [[ -z "$dir" ]] && continue
        [[ "$dir" == "$LOCAL_BIN" ]] && continue
        local c
        for c in "$dir/$tool" "$dir/${tool}.exe" "$dir/${tool}.cmd"; do
            [[ -e "$c" ]] || continue
            if [[ -x "$c" ]] || [[ "$c" == *.cmd ]] || [[ "$c" == *.exe ]]; then
                echo "$c"
                return 0
            fi
        done
    done <<< "${PATH}:"
    return 1
}

# ── Commands ──────────────────────────────────────────────────────────────────

do_wrap() {
    local tool="$1"
    local real_bin="${2:-}"

    require_openbuddy

    # Resolve real binary
    if [[ -z "$real_bin" ]]; then
        real_bin="$(find_real_binary "$tool")" \
            || die "could not find '$tool' in PATH (excluding $LOCAL_BIN)"
    else
        [[ -x "$real_bin" ]] || die "'$real_bin' is not executable"
    fi

    local wrapper="$LOCAL_BIN/$tool"

    # Safety: don't wrap openbuddy itself or openbuddy-wrap
    [[ "$tool" == "openbuddy" || "$tool" == "openbuddy-wrap" ]] \
        && die "cannot wrap openbuddy itself"

    # Warn if already wrapped
    if [[ -f "$wrapper" ]]; then
        # Check if it's one of ours
        if head -3 "$wrapper" 2>/dev/null | grep -q "^# openbuddy wrapper for:"; then
            echo "  '$tool' is already wrapped. Overwriting..."
        else
            die "'$wrapper' exists and is not an openbuddy wrapper. Move it first."
        fi
    fi

    mkdir -p "$LOCAL_BIN"

    cat > "$wrapper" <<WRAPPER
#!/usr/bin/env bash
# openbuddy wrapper for: $tool
# real binary: $real_bin
# generated by: openbuddy-wrap

set -euo pipefail

OPENBUDDY_BIN="$OPENBUDDY"
REAL_BIN="$real_bin"

# Wait so the post-tool buddy panel is readable (skip in CI or if OPENBUDDY_NO_PAUSE_AFTER=1)
_ob_prompt_after_show() {
    [[ -n "\${OPENBUDDY_NO_PAUSE_AFTER:-}" ]] && return 0
    [[ -n "\${CI:-}" ]] && return 0
    echo "" >&2
    read -r -p "[openbuddy] Press Enter to continue… " _ob_done < /dev/tty 2>/dev/null || true
}

if [[ -x "\$OPENBUDDY_BIN" && -z "\${OPENBUDDY_WRAPPED:-}" ]]; then
    export OPENBUDDY_WRAPPED=1

    if [[ -n "\${TMUX:-}" ]]; then
        # Already in tmux: split a buddy pane if nothing here is already running openbuddy watch
        _ob_skip=0
        for _ob_pid in \$(tmux list-panes -F '#{pane_pid}' 2>/dev/null); do
            [[ -z "\$_ob_pid" ]] && continue
            _ob_arg=\$(ps -p "\$_ob_pid" -o args= 2>/dev/null || ps -p "\$_ob_pid" -o command= 2>/dev/null || true)
            case "\$_ob_arg" in *openbuddy*watch*) _ob_skip=1; break ;; esac
        done
        if [[ "\$_ob_skip" -eq 0 ]]; then
            _ob_titles=\$(tmux list-panes -F '#{pane_title}' 2>/dev/null | tr '\\n' ' ')
            case "\$_ob_titles" in *[Oo]penbuddy*watch*) _ob_skip=1 ;; esac
        fi
        if [[ "\$_ob_skip" -eq 0 ]]; then
            tmux split-window -h -p "\${OPENBUDDY_TMUX_PCT:-22}" -d "\$OPENBUDDY_BIN watch" 2>/dev/null || true
        fi
        "\$OPENBUDDY_BIN" session "$tool" --silent 2>/dev/null || true
        [[ -n "\${OPENBUDDY_AUTO_SYNC:-}" ]] && "\$OPENBUDDY_BIN" sync --quiet 2>/dev/null &
        exec "\$REAL_BIN" "\$@"

    elif command -v tmux &>/dev/null && [[ -z "\${OPENBUDDY_NO_TMUX:-}" ]]; then
        # Not in tmux: create a new session with buddy on the right, tool on the left
        "\$OPENBUDDY_BIN" session "$tool" --silent 2>/dev/null || true
        [[ -n "\${OPENBUDDY_AUTO_SYNC:-}" ]] && "\$OPENBUDDY_BIN" sync --quiet 2>/dev/null &
        _sess="openbuddy-\$\$"
        exec tmux new-session -s "\$_sess" \
            -x "\$(tput cols)" -y "\$(tput lines)" \
            "OPENBUDDY_WRAPPED=1 \$REAL_BIN \$(printf '%q ' \"\$@\"); echo; \$OPENBUDDY_BIN show; if [ -z \${OPENBUDDY_NO_PAUSE_AFTER:-} ] && [ -z \${CI:-} ]; then echo >&2; read -r -p '[openbuddy] Press Enter to close… ' _ob_x < /dev/tty 2>/dev/null || true; fi" \; \
            split-window -h -p "\${OPENBUDDY_TMUX_PCT:-22}" -d "\$OPENBUDDY_BIN watch" \; \
            select-pane -t 0

    else
        # No tmux, or OPENBUDDY_NO_TMUX=1: same terminal, buddy after tool exits
        "\$OPENBUDDY_BIN" session "$tool" --silent 2>/dev/null || true
        [[ -n "\${OPENBUDDY_AUTO_SYNC:-}" ]] && "\$OPENBUDDY_BIN" sync --quiet 2>/dev/null &
        "\$REAL_BIN" "\$@"
        _exit=\$?
        "\$OPENBUDDY_BIN" show 2>/dev/null || true
        _ob_prompt_after_show
        exit \$_exit
    fi
else
    exec "\$REAL_BIN" "\$@"
fi
WRAPPER

    chmod +x "$wrapper"

    # On Windows (MSYS/Git Bash), also generate a .cmd wrapper so that
    # PowerShell and cmd.exe pick it up.
    if [[ "$(uname -s)" == MINGW* || "$(uname -s)" == MSYS* ]]; then
        local win_wrapper="$LOCAL_BIN/$tool.cmd"
        local python_exe
        python_exe="$(cygpath -w "$(command -v python 2>/dev/null || command -v python3 2>/dev/null)")" || true
        local openbuddy_win
        openbuddy_win="$(cygpath -w "$OPENBUDDY")" || true
        local node_entry=""
        # Try to find the tool's node entry point for the .cmd wrapper
        local npm_root
        npm_root="$(npm root -g 2>/dev/null)" || true
        if [[ -n "$npm_root" ]]; then
            # Attempt common npm entry patterns
            local real_cmd="$LOCAL_BIN/../AppData/Roaming/npm/$tool.cmd"
            [[ -f "$real_cmd" ]] || real_cmd="$(cygpath -u "$npm_root")/../$tool.cmd"
            if [[ -f "$real_cmd" ]]; then
                # Parse original .cmd to find node entry point
                node_entry="$(grep -oP '(?<=node_modules\\\\)[^"]+' "$real_cmd" 2>/dev/null | head -1)" || true
            fi
        fi
        # Determine the launch command for the real tool
        local run_line
        if [[ -n "$node_entry" ]]; then
            local npm_root_win
            npm_root_win="$(cygpath -w "$npm_root")" || true
            run_line="node \"$npm_root_win\\$node_entry\" %*"
        else
            local real_bin_win
            real_bin_win="$(cygpath -w "$real_bin")" || true
            run_line="\"$real_bin_win\" %*"
        fi

        cat > "$win_wrapper" <<CMDWRAPPER
@echo off
chcp 65001 >nul 2>nul
set PYTHONIOENCODING=utf-8
if defined OPENBUDDY_WRAPPED goto :run
set OPENBUDDY_WRAPPED=1
"$python_exe" "$openbuddy_win" session $tool --silent 2>nul
if defined OPENBUDDY_AUTO_SYNC start /b "" "$python_exe" "$openbuddy_win" sync --quiet 2>nul
if defined OPENBUDDY_POPUP_WATCH (
  start "openbuddy-watch" "$python_exe" "$openbuddy_win" watch
)
:run
$run_line
set OB_EXIT=%ERRORLEVEL%
"$python_exe" "$openbuddy_win" show 2>nul
if not defined OPENBUDDY_NO_PAUSE_AFTER if not defined CI (
  echo.
  set /p OB_=[openbuddy] Press Enter to continue... 
)
exit /b %OB_EXIT%
CMDWRAPPER
        echo "  ✓ Created Windows wrapper: $win_wrapper"
    fi

    echo "  ✓ Wrapped '$tool'"
    echo "    wrapper : $wrapper"
    echo "    real    : $real_bin"
    echo ""
    echo "  Run 'openbuddy session $tool' is called automatically on each launch."
    echo "  Your buddy is at: $OPENBUDDY"
}

do_remove() {
    local tool="$1"
    local wrapper="$LOCAL_BIN/$tool"
    [[ -f "$wrapper" ]] || die "no wrapper found at $wrapper"
    head -3 "$wrapper" 2>/dev/null | grep -q "^# openbuddy wrapper for:" \
        || die "'$wrapper' doesn't look like an openbuddy wrapper"
    rm "$wrapper"
    # Also remove .cmd wrapper on Windows
    [[ -f "$wrapper.cmd" ]] && rm "$wrapper.cmd"
    echo "  ✓ Removed wrapper for '$tool'"
}

do_list() {
    echo ""
    echo "  Wrapped tools in $LOCAL_BIN:"
    echo ""
    local found=0
    for f in "$LOCAL_BIN"/*; do
        [[ -f "$f" ]] || continue
        # Skip .cmd files (listed alongside their bash counterpart)
        [[ "$f" == *.cmd ]] && continue
        # Match only generated wrappers (have both marker lines)
        if head -3 "$f" 2>/dev/null | grep -q "^# openbuddy wrapper for:"; then
            local tool
            tool="$(basename "$f")"
            local real
            real="$(grep "^# real binary:" "$f" | cut -d: -f2- | xargs)"
            local suffix=""
            [[ -f "$f.cmd" ]] && suffix=" (+.cmd)"
            printf "    %-16s → %s%s\n" "$tool" "${real:-unknown}" "$suffix"
            found=1
        fi
    done
    [[ $found -eq 0 ]] && echo "    (none yet — run: openbuddy-wrap <toolname>)"
    echo ""
}

# Preset groups: gemini(재미나이), codex, opencode, claude, aider, … PATH에 있는 것만 래핑
do_preset() {
    local preset="${1:-ai}"
    require_openbuddy
    echo ""
    echo "  openbuddy-wrap — preset: $preset"
    echo ""
    local tools=()
    case "$preset" in
        ai|coding|agents)
            tools=(
                gemini
                codex
                opencode
                claude
                aider
                amp
                crush
                qwen
                kimi
                roocode
            )
            ;;
        *)
            die "unknown preset '$preset' (try: ai)"
            ;;
    esac
    set +e
    local t
    for t in "${tools[@]}"; do
        if find_real_binary "$t" >/dev/null 2>&1; then
            echo "  → wrapping $t"
            do_wrap "$t" || echo "  ! wrap failed for $t (see above)"
        else
            echo "  (skip) $t — not in PATH"
        fi
    done
    set -e
    echo ""
    echo "  Done. Check: openbuddy-wrap --list"
    echo ""
}

# ── Main ──────────────────────────────────────────────────────────────────────

USAGE="Usage: openbuddy-wrap <toolname> [/path/to/real/binary]
       openbuddy-wrap --preset ai      # gemini, codex, opencode, claude, aider, … (PATH에 있는 것만)
       openbuddy-wrap --list
       openbuddy-wrap --remove <toolname>

Examples:
  openbuddy-wrap --preset ai
  openbuddy-wrap codex
  openbuddy-wrap aider
  openbuddy-wrap gh /usr/bin/gh
  openbuddy-wrap --list
  openbuddy-wrap --remove aider
"

case "${1:-}" in
    ""|"-h"|"--help"|"help")
        echo "$USAGE" ;;
    "--list"|"list")
        do_list ;;
    "--remove"|"remove")
        [[ -n "${2:-}" ]] || die "specify a tool name to remove"
        do_remove "$2" ;;
    "--preset"|"preset")
        [[ -n "${2:-}" ]] || die "usage: openbuddy-wrap --preset ai   (presets: ai)"
        do_preset "$2" ;;
    -*)
        die "unknown option: $1" ;;
    *)
        do_wrap "$1" "${2:-}" ;;
esac

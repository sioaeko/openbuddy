#!/usr/bin/env python3
import sys
import os
import time

log_path = "/tmp/openbuddy_sniffer.log"
with open(log_path, "w") as f:
    f.write(f"Sniffer started at {time.ctime()}\n")
    f.write(f"PID: {os.getpid()}, PPID: {os.getppid()}\n")
    f.write(f"TTY: {os.ttyname(sys.stdin.fileno()) if sys.stdin.isatty() else 'not a tty'}\n")
    f.flush()

    # Set non-blocking to read what's already there
    import fcntl
    fd = sys.stdin.fileno()
    fl = fcntl.fcntl(fd, fcntl.F_GETFL)
    fcntl.fcntl(fd, fcntl.F_SETFL, fl | os.O_NONBLOCK)

    try:
        # Wait a bit to see what arrives on startup
        time.sleep(1.0)
        while True:
            try:
                data = sys.stdin.buffer.read(1024)
                if data:
                    f.write(f"Received {len(data)} bytes: {data!r}\n")
                    f.flush()
                else:
                    break
            except BlockingIOError:
                break
    except Exception as e:
        with open(log_path, "a") as f:
            f.write(f"Error: {e}\n")

print("Sniffer finished. Check /tmp/openbuddy_sniffer.log")
